{
  "name": "hn-techpulse-remotion",
  "version": "1.0.0",
  "description": "Remotion renderer for HN TechPulse video pipeline",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx remotion studio src/index.ts --props=public/props.json",
    "dev": "vite --port 3002",
    "dev:open": "vite --port 3002 --open",
    "build": "npx remotion render src/index.ts HNTechPulseComposition out/output.mp4 --props=public/props.json",
    "render": "npx remotion render src/index.ts HNTechPulseComposition out/output.mp4 --props=public/props.json",
    "still": "npx remotion still src/index.ts HNTechPulseComposition out/preview.png --props=public/props.json --frame=0",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "audit": "npm audit --audit-level=moderate",
    "quality": "bash ../../../scripts/ts_quality_check.sh",
    "quality:fix": "bash ../../../scripts/ts_quality_check.sh --fix"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "knip": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.14",
    "vitest": "^3.0.0"
  }
}
