# Remotion runtime assets
**/remotion/public/audio/
**/remotion/public/images/
**/remotion/public/props.json
# Cover background is generated by the cover_image step into data/{date}/,
# then copied to public/ by prepare_render. It's a build output, not a source asset.
**/remotion/public/cover_bg.png
# Manifest sidecars that point at gitignored artifacts (e.g. props.json) leak
# into git; the canonical manifests live under data/{date}/.
**/remotion/public/*.manifest.json

# Remotion render output
**/remotion/out/

